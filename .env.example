DB_PATH=pipeline.db
LEASE_SECONDS=15
MAX_ATTEMPTS=5
RESTAURANT_URL=http://localhost:8001
COURIER_URL=http://localhost:8002
WORKER_POLL_INTERVAL=0.1
WORKER_COUNT=12
HEARTBEAT_INTERVAL=2.0

# Simulated processing time. Steps take a realistic, variable duration expressed
# in minutes (config.py STEP_DURATION_MINUTES) compressed by TIME_SCALE seconds
# per simulated minute. 0.05 -> a 10-30 min "preparing" step takes 0.5-1.5 s.
# Raise toward 1.0 to watch closer to real time; lower for a faster demo.
TIME_SCALE=0.05
SLOW_FACTOR=8.0
TRANSIENT_ERROR_RATE=0.10

# An order's placed->delivered latency past this is an SLA breach (dashboard + /metrics).
SLA_THRESHOLD_SECONDS=30

# Circuit breaker per downstream: open after this many CONSECUTIVE failures
# (must clear the TRANSIENT_ERROR_RATE noise floor at realistic call volume —
# see the comment in config.py); half-open probe after this many seconds.
CIRCUIT_BREAKER_THRESHOLD=6
CIRCUIT_BREAKER_COOLDOWN_SECONDS=10
